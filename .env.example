# FalkorDB connection (Render private service URL)
FALKORDB_HOST=falkordb-internal
FALKORDB_PORT=6379
FALKORDB_PASSWORD=your-secure-password-here

# Anthropic API key (shared with Engage backend)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM model for entity extraction (Haiku for cost efficiency)
GRAPHITI_LLM_MODEL=claude-haiku-4-5-20251001

# OpenAI API key for embeddings (Graphiti default embedding provider)
OPENAI_API_KEY=sk-your-openai-key-here

# Service settings
PORT=8000
LOG_LEVEL=info
